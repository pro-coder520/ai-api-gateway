# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
POSTGRES_DB=ai_gateway
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway_secret
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://gateway:gateway_secret@localhost:5432/ai_gateway

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ──────────────────────────────────────────────
# FastAPI Gateway
# ──────────────────────────────────────────────
GATEWAY_PORT=8000
GATEWAY_SECRET_KEY=change-me-to-a-random-secret
GATEWAY_DEBUG=true
GATEWAY_LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# Django Admin Portal
# ──────────────────────────────────────────────
ADMIN_PORT=8001
DJANGO_SECRET_KEY=change-me-to-a-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,admin

# ──────────────────────────────────────────────
# LLM Provider API Keys
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_API_BASE=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_API_BASE=https://api.anthropic.com
OLLAMA_API_BASE=http://localhost:11434

# ──────────────────────────────────────────────
# Rate Limiting Defaults
# ──────────────────────────────────────────────
DEFAULT_RATE_LIMIT_CAPACITY=60
DEFAULT_RATE_LIMIT_REFILL_RATE=1
DEFAULT_DAILY_TOKEN_LIMIT=1000000

# ──────────────────────────────────────────────
# Cache
# ──────────────────────────────────────────────
CACHE_DEFAULT_TTL=3600
CACHE_ENABLED=true

# ──────────────────────────────────────────────
# Circuit Breaker
# ──────────────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30
CB_HALF_OPEN_MAX_REQUESTS=3

# ──────────────────────────────────────────────
# Celery (Django side)
# ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/2
